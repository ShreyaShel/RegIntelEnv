# RegIntelEnv Environment Variables
# Copy this file to .env and fill in your values

# ---- OpenAI API ---------------------------------------------------
# Required for running inference.py
OPENAI_API_KEY=sk-your-key-here

# Model to use (default: gpt-4o-mini for cost-efficiency)
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
MODEL_NAME=gpt-4o-mini

# ---- Server Configuration -----------------------------------------
# Port to run the FastAPI server on (7860 = Hugging Face Spaces default)
PORT=7860

# ---- Feature Flags ------------------------------------------------
# Enable the built-in web UI at /web
ENABLE_WEB_INTERFACE=true

# ---- Inference Client  -------------------------------------------
# URL of the running RegIntelEnv server (for inference.py)
BASE_URL=http://localhost:7860
